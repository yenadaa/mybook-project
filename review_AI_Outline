# main.py
# -*- coding: utf-8 -*-
"""
MyBook Review API (Firebase 백엔드/Cloud Run용)
- FastAPI 기반 HTTP 서버
- 입력: 전처리 파이프라인 산출 JSON(문서 하단의 expected schema 참고)
- 기능:
  1) 다층 요약 (300자 / A4 반쪽 / A4 한쪽)
  2) 키워드 기반 문항 생성 (빈칸/관계/발췌 + OX/단답/토론)
  3) 문항 수는 적당한 범위에서 임의 자동 배분(엔드포인트별 파라미터로 조절 가능)

배포:
- Firebase Hosting ↔ Cloud Run 라우팅(권장) 또는 GCF(Gen2)에서도 ASGI 지원 가능.
- 환경변수 OPENAI_API_KEY 필요.
"""

from __future__ import annotations
import os, json, random, re, time, textwrap
from typing import Any, Dict, List, Optional, Tuple

from fastapi import FastAPI, Body, Query
from pydantic import BaseModel, Field
from openai import OpenAI
from starlette.responses import JSONResponse

# --------------------------- OpenAI client ---------------------------
def get_client() -> "OpenAI":
    api_key = os.environ.get("OPENAI_API_KEY")
    if not api_key:
        raise RuntimeError("환경변수 OPENAI_API_KEY가 필요합니다.")
    return OpenAI(api_key=api_key)

# --------------------------- 데이터 모델 ----------------------------
class Chunk(BaseModel):
    id: Optional[str] = None
    text: str
    section_path: Optional[List[str]] = None
    anchors: Optional[List[str]] = None
    neighbors: Optional[Dict[str, Optional[str]]] = None
    span_offsets: Optional[List[List[int]]] = None

class PreprocessedDoc(BaseModel):
    doc_id: Optional[str] = None
    chunks: List[Chunk]

class SummaryOut(BaseModel):
    summary_300: str
    summary_half: str
    summary_full: str
    sources: List[str]

class ClozeItem(BaseModel):
    type: str
    question: str
    answer: Any
    sources: List[str]
    tags: List[str] = Field(default_factory=list)
    confused: bool = False
    blanks: Optional[List[str]] = None  # excerpt_blank 용

class ReviewOut(BaseModel):
    ox: List[Dict[str, Any]]
    short: List[Dict[str, Any]]
    discussion: List[Dict[str, Any]]

class QuestionsOut(BaseModel):
    keywords_used: List[str]
    cloze: List[ClozeItem]
    review: ReviewOut

class BothOut(BaseModel):
    summaries: SummaryOut
    questions: QuestionsOut
    meta: Dict[str, Any]

# ------------------------ 스코프/선택 유틸 --------------------------
def normalize_ids(doc: PreprocessedDoc) -> None:
    for i, ch in enumerate(doc.chunks):
        if not ch.id:
            ch.id = f"c{i}"

def select_scope(
    doc: PreprocessedDoc,
    section_contains: Optional[str],
    chunk_ids: Optional[List[str]],
    auto_chars: int = 4000,
) -> Tuple[str, List[str]]:
    chunks = doc.chunks
    if section_contains:
        selected = [
            c for c in chunks
            if section_contains in " / ".join(c.section_path or [])
        ]
    elif chunk_ids:
        s = set(chunk_ids)
        selected = [c for c in chunks if c.id in s]
    else:
        selected, total = [], 0
        for c in chunks:
            t = c.text or ""
            if not t.strip():
                continue
            if total + len(t) > auto_chars and total > 0:
                break
            selected.append(c)
            total += len(t)
    if not selected:
        raise ValueError("선택된 범위가 비어 있습니다. section 또는 chunk_ids를 확인하세요.")
    joined, ids = [], []
    for c in selected:
        ids.append(c.id)
        sp = c.section_path or []
        header = f"[# {' › '.join(sp)}]\n" if sp else ""
        joined.append(header + (c.text or ""))
    return "\n\n".join(joined), ids

# ------------------------ 프롬프트 템플릿 --------------------------
def system_prompt() -> str:
    return (
        "당신은 교재 기반 학습 도우미입니다. 제공된 텍스트만을 근거로 요약/문항을 만듭니다. "
        "각 결과에는 가능한 한 출처(chunk id)를 포함하세요."
    )

def prompt_summaries(text: str) -> str:
    return textwrap.dedent(f"""
    [과제]
    아래 텍스트를 근거로 세 가지 길이의 요약을 만드세요.
    - 요약A(약 300자 이내): 핵심만 1문단.
    - 요약B(약 A4 반쪽=600~800자): 핵심 논지+핵심 근거. 중요한 개념은 굵게(별표) 표기: *개념*.
    - 요약C(약 A4 한쪽=1200~1600자): 구조적 요약(배경→핵심 주장→근거/예시→시사점).

    [출처 표기]
    - 각 요약 끝에 참고한 chunk id를 대괄호로 나열: [c1,c2,...]

    [텍스트]
    {text}

    [출력(JSON)]
    {{
      "summary_300": "...",
      "summary_half": "...",
      "summary_full": "...",
      "sources": ["c1","c2","..."]
    }}
    """).strip()

def prompt_questions(text: str, keywords: List[str], counts: Dict[str, int]) -> str:
    kws = ", ".join(keywords)
    # counts: cloze_desc_to_term, cloze_term_to_desc, cloze_relation, cloze_excerpt,
    #         ox, short, discussion
    return textwrap.dedent(f"""
    [과제]
    아래 텍스트와 키워드를 근거로 학습용 문제를 생성하세요.

    [키워드]
    {kws}

    [문항 수(정확히 맞춰 생성)]
    - 지문→개념(desc_to_term): {counts['cloze_desc_to_term']}문항
    - 개념→설명(term_to_desc): {counts['cloze_term_to_desc']}문항
    - 관계 설명(relation): {counts['cloze_relation']}문항
    - 발췌-빈칸(excerpt_blank): {counts['cloze_excerpt']}문항
    - OX: {counts['ox']}문항
    - 단답: {counts['short']}문항
    - 토론: {counts['discussion']}문항

    [형식]
    1) 빈칸형 4유형
       - desc_to_term: 설명 지문을 주고 답은 개념명
       - term_to_desc: 개념명을 주고 간결 정의/핵심
       - relation: 2~3개 개념의 관계/차이/인과
       - excerpt_blank: 원문을 재진술하고 핵심 용어를 ___ 처리, "blanks": ["용어A", ...] 포함
    2) 복습용
       - OX: 근거 한 줄("why")
       - 단답: 핵심 키워드로 답 가능
       - 토론: 흥미 유도 질문 + 짧은 힌트

    [제약]
    - 텍스트 밖의 지식을 끌어오지 말 것
    - 각 문항에는 최소 1개 이상의 출처 chunk id 첨부
    - 정답/해설은 간결하게
    - 출력 JSON 스키마를 엄격히 준수

    [출력(JSON)]
    {{
      "cloze": [
        {{"type":"desc_to_term","question":"...","answer":"...","sources":["c2"],"tags":["빈칸","개념"],"confused":false}},
        {{"type":"term_to_desc","question":"...","answer":"...","sources":["c1"],"tags":["빈칸","정의"],"confused":false}},
        {{"type":"relation","question":"...","answer":"...","sources":["c1","c3"],"tags":["관계"],"confused":false}},
        {{"type":"excerpt_blank","question":"...","answer":"...","blanks":["..."],"sources":["c4"],"tags":["발췌"],"confused":false}}
      ],
      "review": {{
        "ox":    [{{"q":"...","answer":true,"why":"...","sources":["c1"],"tags":["OX"],"confused":false}}],
        "short": [{{"q":"...","answer":"...","sources":["c2"],"tags":["단답"],"confused":false}}],
        "discussion": [{{"q":"...","hint":"...","sources":["c3"],"tags":["토론"]}}]
      }}
    }}

    [텍스트]
    {text}
    """).strip()

# ------------------------ GPT 호출 -----------------------------
def ask_gpt_json(prompt: str, model: str, temperature: float, max_output_tokens: int) -> Any:
    client = get_client()
    rsp = client.responses.create(
        model=model,
        temperature=temperature,
        max_output_tokens=max_output_tokens,
        input=[
            {"role": "system", "content": system_prompt()},
            {"role": "user", "content": prompt},
        ],
        response_format={"type": "json_object"},
    )
    return json.loads(rsp.output_text)

# ------------------------ 보정/후처리 ---------------------------
def fix_sources_list(candidate: List[str], valid_ids: List[str], fallback: List[str]) -> List[str]:
    valid = set(valid_ids)
    out = [s for s in (candidate or []) if s in valid]
    return out or (fallback if fallback else (valid_ids[:1] if valid_ids else []))

def ensure_ids(doc: PreprocessedDoc) -> List[str]:
    normalize_ids(doc)
    return [c.id for c in doc.chunks]

def default_keywords(doc: PreprocessedDoc, k: int = 5) -> List[str]:
    bag: List[str] = []
    for c in doc.chunks:
        if c.anchors:
            bag.extend([a for a in c.anchors if isinstance(a, str) and a.strip()])
    if not bag:
        return ["핵심 개념", "정의", "관계", "예시", "의의"][:k]
    # 순서 보존 dedup
    seen, out = set(), []
    for a in bag:
        if a not in seen:
            out.append(a)
            seen.add(a)
    return out[:k]

def auto_counts(seed: Optional[int] = None) -> Dict[str, int]:
    """
    문항 수를 적당한 범위에서 임의 배분.
    - 빈칸형(총 6~10): desc_to_term 2~3, term_to_desc 2~3, relation 1~2, excerpt 1~2
    - OX 3~5, 단답 3~6, 토론 2~3
    """
    rnd = random.Random(seed)
    return {
        "cloze_desc_to_term": rnd.randint(2, 3),
        "cloze_term_to_desc": rnd.randint(2, 3),
        "cloze_relation": rnd.randint(1, 2),
        "cloze_excerpt": rnd.randint(1, 2),
        "ox": rnd.randint(3, 5),
        "short": rnd.randint(3, 6),
        "discussion": rnd.randint(2, 3),
    }

# ------------------------ 비즈니스 로직 --------------------------
def run_summaries_api(
    doc: PreprocessedDoc,
    section: Optional[str],
    chunk_ids: Optional[List[str]],
    model: str = "gpt-4.1-mini",
) -> SummaryOut:
    all_ids = ensure_ids(doc)
    text, used_ids = select_scope(doc, section, chunk_ids)
    data = ask_gpt_json(prompt_summaries(text), model=model, temperature=0.2, max_output_tokens=1600)
    # 출처 보정
    data["sources"] = fix_sources_list(data.get("sources", []), all_ids, used_ids)
    return SummaryOut(**data)

def run_questions_api(
    doc: PreprocessedDoc,
    section: Optional[str],
    chunk_ids: Optional[List[str]],
    keywords: Optional[List[str]],
    model: str = "gpt-4.1-mini",
    seed: Optional[int] = None,
    counts_override: Optional[Dict[str, int]] = None,
) -> QuestionsOut:
    all_ids = ensure_ids(doc)
    text, used_ids = select_scope(doc, section, chunk_ids)
    kws = keywords or default_keywords(doc)
    counts = counts_override or auto_counts(seed=seed)

    raw = ask_gpt_json(
        prompt_questions(text, kws, counts),
        model=model, temperature=0.4, max_output_tokens=2200
    )

    # 일괄 출처/태그 보정
    def _fix_item(item: Dict[str, Any]) -> Dict[str, Any]:
        item["sources"] = fix_sources_list(item.get("sources", []), all_ids, used_ids[:1])
        tags = item.get("tags") or []
        t = item.get("type")
        if t and t not in tags:
            tags.append(t)
        item["tags"] = tags
        item.setdefault("confused", False)
        return item

    cloze = [_fix_item(it) for it in (raw.get("cloze") or [])]
    rv = raw.get("review", {}) or {}
    ox = [_fix_item(it) for it in (rv.get("ox") or [])]
    short = [_fix_item(it) for it in (rv.get("short") or [])]
    discussion = []
    for it in (rv.get("discussion") or []):
        it["sources"] = fix_sources_list(it.get("sources", []), all_ids, used_ids[:1])
        it["tags"] = (it.get("tags") or []) or ["discussion"]
        discussion.append(it)

    return QuestionsOut(
        keywords_used=kws,
        cloze=[ClozeItem(**it) for it in cloze],
        review=ReviewOut(ox=ox, short=short, discussion=discussion)
    )

# ------------------------ FastAPI 앱 ------------------------------
app = FastAPI(title="MyBook Review API", version="0.1.0")

@app.post("/summaries", response_model=SummaryOut)
def api_summaries(
    doc: PreprocessedDoc = Body(..., description="전처리 산출 JSON"),
    section: Optional[str] = Query(None, description="섹션 문자열 부분일치"),
    chunk_ids_csv: Optional[str] = Query(None, description="예: c0,c1,c2"),
    model: str = Query("gpt-4.1-mini"),
):
    chunk_ids = [s.strip() for s in chunk_ids_csv.split(",")] if chunk_ids_csv else None
    try:
        out = run_summaries_api(doc, section, chunk_ids, model=model)
        return out
    except Exception as e:
        return JSONResponse({"error": str(e)}, status_code=400)

@app.post("/questions", response_model=QuestionsOut)
def api_questions(
    doc: PreprocessedDoc = Body(...),
    section: Optional[str] = Query(None),
    chunk_ids_csv: Optional[str] = Query(None),
    model: str = Query("gpt-4.1-mini"),
    keywords_csv: Optional[str] = Query(None, description="키워드 콤마열"),
    seed: Optional[int] = Query(None, description="랜덤 시드(재현성)"),
    # counts override (선택): 미지정 시 auto 임의 배분
    c_desc_to_term: Optional[int] = Query(None),
    c_term_to_desc: Optional[int] = Query(None),
    c_relation: Optional[int] = Query(None),
    c_excerpt: Optional[int] = Query(None),
    c_ox: Optional[int] = Query(None),
    c_short: Optional[int] = Query(None),
    c_discussion: Optional[int] = Query(None),
):
    chunk_ids = [s.strip() for s in chunk_ids_csv.split(",")] if chunk_ids_csv else None
    keywords = [s.strip() for s in keywords_csv.split(",")] if keywords_csv else None
    counts_override = None
    if any(v is not None for v in [c_desc_to_term, c_term_to_desc, c_relation, c_excerpt, c_ox, c_short, c_discussion]):
        counts_override = {
            "cloze_desc_to_term": c_desc_to_term or 0,
            "cloze_term_to_desc": c_term_to_desc or 0,
            "cloze_relation": c_relation or 0,
            "cloze_excerpt": c_excerpt or 0,
            "ox": c_ox or 0,
            "short": c_short or 0,
            "discussion": c_discussion or 0,
        }
    try:
        out = run_questions_api(
            doc, section, chunk_ids, keywords, model=model, seed=seed, counts_override=counts_override
        )
        return out
    except Exception as e:
        return JSONResponse({"error": str(e)}, status_code=400)

@app.post("/both", response_model=BothOut)
def api_both(
    doc: PreprocessedDoc = Body(...),
    section: Optional[str] = Query(None),
    chunk_ids_csv: Optional[str] = Query(None),
    model: str = Query("gpt-4.1-mini"),
    keywords_csv: Optional[str] = Query(None),
    seed: Optional[int] = Query(None),
):
    chunk_ids = [s.strip() for s in chunk_ids_csv.split(",")] if chunk_ids_csv else None
    keywords = [s.strip() for s in keywords_csv.split(",")] if keywords_csv else None
    try:
        summaries = run_summaries_api(doc, section, chunk_ids, model=model)
        questions = run_questions_api(doc, section, chunk_ids, keywords, model=model, seed=seed)
        return BothOut(
            summaries=summaries,
            questions=questions,
            meta={"model": model, "doc_id": doc.doc_id}
        )
    except Exception as e:
        return JSONResponse({"error": str(e)}, status_code=400)

